# ==========================================
# .NET / C# / IDEs (Visual Studio / Rider)
# ==========================================
# Build results
bin/
obj/

# Visual Studio specific files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# JetBrains Rider / ReSharper specific files
.idea/
*.sln.iml

# Local configuration files (keep secrets out of source control)
appsettings.Development.json
appsettings.Local.json

# ==========================================
# RavenDB
# ==========================================
# Ignore local database files and directories if you are 
# running RavenDB embedded or storing local test data
RavenData/
*.ravendb-test-data
Data/

# ==========================================
# Frontend (React / Angular / Vue / etc.)
# ==========================================
# Dependency directories
node_modules/

# Production build outputs
dist/
build/
out/

# Environment variables (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# NPM / Yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# OS / General (macOS / Windows)
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/